# Session - min 32 chars (generate: openssl rand -base64 32)
SESSION_SECRET=""

# Upstash Rate Limit (optional, but recommended for public/serverless deploy)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# GitLab
GITLAB_URL="https://gitlab.com"

# OpenRouter
OPENROUTER_API_KEY="" # Dapatkan di https://openrouter.ai/keys
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# Runtime
NODE_ENV="development"
